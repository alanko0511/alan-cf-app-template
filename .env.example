# drizzle-kit (db:push / db:generate / db:migrate / db:seed) connects to Postgres
# DIRECTLY — not through Hyperdrive. If DATABASE_URL is unset it defaults to the
# local docker-compose Postgres. Set it to your production database's direct
# connection string when generating/applying migrations against prod.
#
# The Worker's *runtime* connection is configured separately, via the Hyperdrive
# binding in wrangler.json (id + localConnectionString) — not this file.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app
